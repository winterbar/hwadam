<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.miles.beauminity.mapper.board.MasterBoardLikeMapper">

    <!-- 좋아요 추가 -->
    <insert id="insertLike"
            parameterType="com.miles.beauminity.vo.board.MasterBoardLikeVO">
            INSERT INTO board_like
            (board_id, username)
            VALUES
            (#{boardId}, #{username})
    </insert>

    <!-- 좋아요 여부 확인 -->
    <select id="isLikeON"
            parameterType="com.miles.beauminity.vo.board.MasterBoardLikeVO"
            resultType="com.miles.beauminity.vo.board.MasterBoardLikeVO">
        SELECT *
        FROM board_like
        WHERE username = #{username} AND board_id = #{boardId}
    </select>   

    <!-- 좋아요 삭제 -->
    <delete id="deleteLike"
            parameterType="com.miles.beauminity.vo.board.MasterBoardLikeVO">
            DELETE FROM board_like
            WHERE username = #{username} AND board_id = #{boardId}
    </delete>

    <!-- 좋아요 수 확인 -->
    <select id="getLikeCount"
            parameterType="Long"
            resultType="Int">
        SELECT COUNT(*)
        FROM board_like
        WHERE board_id = #{value};
   </select> 

   

</mapper>