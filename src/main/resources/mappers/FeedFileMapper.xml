<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.miles.beauminity.mapper.FeedFileMapper">
    <insert id="postFile"
            keyProperty="fileId">
        insert into feed_file(
            feed_id,
            original_name,
            saved_name,
            file_path,
            file_type,
            file_size
        )
        values(
            #{feedId},
            #{originalName},
            #{savedName},
            #{filePath},
            #{fileType},
            #{fileSize}
        )
    </insert>
</mapper>
