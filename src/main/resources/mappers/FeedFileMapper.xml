<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.miles.beauminity.mapper.FeedFileMapper">

    <!-- 파일 등록 -->
    <insert id="postFile"
            keyProperty="fileId">
        insert into feed_file(
            feed_id,
            original_name,
            saved_name,
            file_path,
            file_type,
            file_size
        )
        values(
            #{feedId},
            #{originalName},
            #{savedName},
            #{filePath},
            #{fileType},
            #{fileSize}
        )
    </insert>

    <!--해당 피드의 파일 저장명 가져오기-->
    <select id="getFeedFileList" parameterType="long" 
    resultType="string">
        select saved_name
        from feed_file
        where feed_id = #{feedId}
        order by file_id asc
    </select>

    <!--특정 피드 파일 삭제-->
    <delete id="deleteFile"
            parameterType="com.miles.beauminity.vo.feed.FeedVO">
        delete from feed_file
        where feed_id=#{feedId}
    </delete>

    <!-- 저장된 파일 리스트 가져오기 -->
    <select id="getFileListByFeedId"
        parameterType="long"
        resultType="com.miles.beauminity.vo.feed.FeedFileVO">
    select
        file_id,
        feed_id,
        original_name,
        saved_name,
        file_path,
        file_type,
        file_size
    from feed_file
    where feed_id = #{feedId}
    order by file_id asc
</select>

</mapper>
